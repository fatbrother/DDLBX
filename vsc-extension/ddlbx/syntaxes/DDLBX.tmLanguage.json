{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "DDLBX",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#constant"
    },
    {
      "include": "#variable"
    },
    {
      "include": "#function"
    },
    {
      "include": "#type"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ddlbx",
          "match": "\\b(if|while|for|return)\\b"
        },
        {
          "name": "keyword.operator.ddlbx",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.ddlbx",
          "match": "\\b(maybe|true|false)\\b"
        },
        {
          "name": "storage.type.ddlbx",
          "match": "\\b(var)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ddlbx",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ddlbx",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "name": "comment.ddlbx",
      "patterns": [
        {
          "name": "comment.line.double-slash.ddlbx",
          "match": "//.*"
        },
        {
          "name": "comment.block.ddlbx",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.numeric.ddlbx",
          "match": "\\b(0x[0-9a-fA-F]+|\\d+)\\b"
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "name": "variable.other.ddlbx",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "function": {
      "patterns": [
        {
          "name": "entity.name.function.ddlbx",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\()"
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "name": "storage.type.ddlbx",
          "match": "\\b(Int|Flo|Boo|Non|Str)\\b"
        }
      ]
    }
  },
  "scopeName": "source.ddlbx"
}
